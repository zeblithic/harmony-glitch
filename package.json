{
  "name": "harmony-glitch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "extract-items": "cargo run --manifest-path src-tauri/Cargo.toml --features extract-swf --bin extract-swf -- --source ${GLITCH_ART_PATH:-$HOME/work/tinyspeck/glitch-items} --output tools/asset-pipeline/extracted/items",
    "pack-items": "node tools/asset-pipeline/pack.mjs --input tools/asset-pipeline/extracted/items --output assets/sprites/items --name items",
    "pipeline-items": "npm run extract-items && npm run pack-items"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/api": "^2.10.1",
    "howler": "^2.2.4",
    "pixi.js": "^8.16.0",
    "svelte": "^5.53.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/howler": "^2.2.12",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "vitest": "^4.0.18"
  }
}
